; Engine configuration for Battle of Megiddo RTS
; Godot 4.7.1 — 3D touch-first Egyptian campaign

config_version=5

[application]

config/name="Hang Megiddo — Battle of Megiddo"
config/description="Real-time strategy: Thutmose III at Megiddo, c. 1457 BCE. Touch-first 3D."
config/version="0.1.0"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

AudioManager="*res://scripts/audio_manager.gd"

[display]

window/size/viewport_width=1600
window/size/viewport_height=900
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=4

[input_devices]

pointing/emulate_touch_from_mouse=true

[rendering]

renderer/rendering_method="forward_plus"
anti_aliasing/quality/msaa_3d=2
lights_and_shadows/directional_shadow/size=4096

[layer_names]

3d_physics/layer_1="terrain"
3d_physics/layer_2="units"
3d_physics/layer_3="buildings"
